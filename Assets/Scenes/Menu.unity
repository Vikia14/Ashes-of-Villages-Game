--- !u!114 &1021398183
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1021398181}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 29b986d4e08922b479666c9b88c2b7d8, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  _lines:
  - "\u042F \u0440\u043E\u0434\u0438\u043B\u0430\u0441\u044C \u0438 \u0432\u044B\u0440\u043E\u0441\u043B\u0430
    \u0432 \u0434\u0435\u0440\u0435\u0432\u043D\u0435, \u0432 \u0433\u043B\u0443\u0448\u0438
    \u043D\u0430\u0448\u0435\u0433\u043E \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0441\u0442\u0432\u0430.
    \u0421 10 \u043B\u0435\u0442 \u044F \u043E\u0441\u0442\u0430\u043B\u0430\u0441\u044C
    \u0441\u0438\u0440\u043E\u0442\u043E\u0439. \u041C\u043E\u0439 \u043E\u0442\u0435\u0446
    \u0431\u044B\u043B \u0440\u044B\u0446\u0430\u0440\u0435\u043C, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0437\u0430\u0449\u0438\u0449\u0430\u043B \u043D\u0430\u0448\u0443 \u0434\u0435\u0440\u0435\u0432\u043D\u044E
    \u0438 \u043F\u043E\u0433\u0438\u0431 \u0432 \u043E\u0434\u043D\u043E\u0439 \u0438\u0437
    \u0432\u044B\u043B\u0430\u0437\u043E\u043A, \u0437\u0430\u0449\u0438\u0449\u0430\u044F
    \u043D\u0430\u0448\u0443 \u0434\u0435\u0440\u0435\u0432\u043D\u044E, \u043A\u043E\u0433\u0434\u0430
    \u0443\u043D\u0438\u0447\u0442\u043E\u0436\u0430\u043B \u043C\u043E\u043D\u0441\u0442\u0440\u043E\u0432,
    \u043F\u043E\u0434\u043E\u0431\u0440\u0430\u0432\u0448\u0438\u0445\u0441\u044F
    \u0441\u043B\u0438\u0448\u043A\u043E\u043C \u0431\u043B\u0438\u0437\u043A\u043E
    \u043A \u0434\u0435\u0440\u0435\u0432\u043D\u0435."
  - "\u0410 \u043C\u043E\u044F \u043C\u0430\u0442\u044C \u0443\u043C\u0435\u0440\u043B\u0430,
    \u043A\u043E\u0433\u0434\u0430 \u044F \u0431\u044B\u043B\u0430 \u0441\u043E\u0432\u0441\u0435\u043C
    \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u043E\u0439, \u0438 \u044F \u0434\u0430\u0436\u0435
    \u043D\u0435 \u043F\u043E\u043C\u043D\u044E \u0435\u0435 \u043B\u0438\u0446\u0430.
    \u0421\u0435\u0439\u0447\u0430\u0441 \u044F \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u044F\u044F
    \u043D\u0430\u0434\u0435\u0436\u0434\u0430 \u0441\u0432\u043E\u0435\u0439 \u0434\u0435\u0440\u0435\u0432\u043D\u0438
    \u043D\u0430 \u0432\u044B\u0436\u0438\u0432\u0430\u043D\u0438\u0435, \u0442\u0430\u043A,
    \u043A\u0430\u043A \u0442\u043E\u043B\u044C\u043A\u043E \u0443 \u043C\u0435\u043D\u044F
    \u0435\u0441\u0442\u044C \u0434\u0430\u0440, \u0445\u043E\u0442\u044C \u0438
    \u0441\u043B\u0430\u0431\u044B\u0439, \u043D\u043E \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u044E\u0449\u0438\u0439
    \u043F\u0435\u0440\u0435\u0436\u0438\u0442\u044C \u0430\u0442\u0430\u043A\u0443
    \u0441\u043A\u0435\u043B\u0435\u0442\u0430 \u0438 \u0434\u0430\u044E\u0449\u0438\u0439
    \u043D\u0435\u0432\u043E\u0441\u043F\u0440\u0438\u0438\u043C\u0447\u0438\u0432\u043E\u0441\u0442\u044C
    \u043A \u0442\u0451\u043C\u043D\u043E\u0439 \u044D\u043D\u0435\u0440\u0433\u0438\u0438."
  - "\u041C\u043E\u043D\u0441\u0442\u0440\u044B \u043E\u0431\u043B\u0430\u0434\u0430\u044E\u0442
    \u044D\u043D\u0435\u0440\u0433\u0438\u0435\u0439, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u043F\u0440\u0438 \u043F\u043E\u043F\u0430\u0434\u0430\u043D\u0438\u0438 \u0432
    \u043E\u0431\u044B\u0447\u043D\u043E\u0433\u043E \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430,
    \u043D\u0435 \u043E\u0431\u043B\u0430\u0434\u0430\u044E\u0449\u0435\u0433\u043E
    \u0434\u0430\u0440\u043E\u043C, \u0433\u0430\u0440\u0430\u043D\u0442\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u043E
    \u0435\u0433\u043E \u0443\u0431\u0438\u0432\u0430\u0435\u0442. \u0411\u0435\u0437
    \u0431\u044B\u0441\u0442\u0440\u043E\u0439 \u043F\u043E\u043C\u043E\u0449\u0438
    \u0446\u0435\u043B\u0438\u0442\u0435\u043B\u044F \u043F\u043E\u0441\u043B\u0435
    \u0441\u043C\u0435\u0440\u0442\u0438 \u0447\u0435\u043B\u043E\u0432\u0435\u043A
    \u043C\u043E\u0436\u0435\u0442 \u0441\u0442\u0430\u0442\u044C \u043C\u043E\u043D\u0441\u0442\u0440\u043E\u043C,
    \u043F\u043E\u044D\u0442\u043E\u043C\u0443 \u043E\u0447\u0435\u043D\u044C \u0447\u0430\u0441\u0442\u043E
    \u0434\u0435\u0440\u0435\u0432\u043D\u0438, \u043E\u0441\u0442\u0430\u0432\u0448\u0438\u0435\u0441\u044F
    \u0431\u0435\u0437 \u0437\u0430\u0449\u0438\u0442\u044B \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430
    \u0441 \u0434\u0430\u0440\u043E\u043C, \u043F\u0440\u043E\u0441\u0442\u043E \u0441\u0436\u0438\u0433\u0430\u044E\u0442."
  - "\u0415\u0441\u043B\u0438 \u044F \u043F\u043E\u0433\u0438\u0431\u043D\u0443 \u0432
    \u0431\u043E\u044E, \u043C\u043E\u044F \u0434\u0435\u0440\u0435\u0432\u043D\u044F
    \u043B\u0438\u0431\u043E \u043F\u0440\u0435\u0432\u0440\u0430\u0442\u0438\u0442\u0441\u044F
    \u0432 \u043C\u043E\u043D\u0441\u0442\u0440\u043E\u0432, \u043B\u0438\u0431\u043E,
    \u0435\u0441\u043B\u0438 \u043A\u043E\u0440\u043E\u043B\u044C \u0440\u0435\u0448\u0438\u0442
    \u0432\u0441\u043F\u043E\u043C\u043D\u0438\u0442\u044C \u043E \u043D\u0430\u0441,
    \u0434\u0435\u0440\u0435\u0432\u043D\u044E \u0441\u043E\u0436\u0433\u0443\u0442,
    \u0442\u0430\u043A \u043A\u0430\u043A \u043D\u0438\u043A\u0442\u043E \u043D\u0435
    \u0441\u0442\u0430\u043D\u0435\u0442 \u0432\u044B\u0434\u0435\u043B\u044F\u0442\u044C
    \u0440\u0435\u0434\u043A\u0438\u0445 \u043E\u0434\u0430\u0440\u0451\u043D\u043D\u044B\u0445
    \u0434\u043B\u044F \u0437\u0430\u0449\u0438\u0442\u044B \u043F\u043E\u0434\u0434\u0430\u043D\u043D\u044B\u0445
    \u0432 \u0442\u0430\u043A\u043E\u0439 \u0433\u043B\u0443\u0448\u0438."
  _speedText: 0.01
  _badEnd: {fileID: 506038416}
